<!doctype html><html><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/><title>VivaPure Water</title></head><body><div id="root"></div><script type="module" src="/src/main.jsx"></script></body></html>
import {Routes,Route,Navigate} from 'react-router-dom';import Navbar from './components/Navbar.jsx';import Home from './pages/Home.jsx';import Contact from './pages/Contact.jsx';import Login from './pages/Login.jsx';import Dashboard from './pages/Dashboard.jsx';import WaterTests from './pages/WaterTests.jsx';import Finance from './pages/Finance.jsx';import Maintenance from './pages/Maintenance.jsx';import Invoices from './pages/Invoices.jsx';function Protected({children}){const loggedIn=localStorage.getItem('vivapure_staff')==='true';return loggedIn?children:<Navigate to="/login"/>}export default function App(){return <><Navbar/><Routes><Route path="/" element={<Home/>}/><Route path="/contact" element={<Contact/>}/><Route path="/login" element={<Login/>}/><Route path="/dashboard" element={<Protected><Dashboard/></Protected>}/><Route path="/water-tests" element={<Protected><WaterTests/></Protected>}/><Route path="/finance" element={<Protected><Finance/></Protected>}/><Route path="/maintenance" element={<Protected><Maintenance/></Protected>}/><Route path="/invoices" element={<Protected><Invoices/></Protected>}/></Routes></>}
import React from 'react';import {createRoot} from 'react-dom/client';import {BrowserRouter} from 'react-router-dom';import App from './App.jsx';import './styles/main.css';createRoot(document.getElementById('root')).render(<BrowserRouter><App/></BrowserRouter>);
import {Link,useNavigate} from 'react-router-dom';export default function Navbar(){const navigate=useNavigate();const loggedIn=localStorage.getItem('vivapure_staff')==='true';function logout(){localStorage.removeItem('vivapure_staff');navigate('/')}return <nav className="nav"><Link className="brand" to="/">VivaPure</Link><div><Link to="/">Home</Link><Link to="/contact">Contact</Link>{loggedIn&&<Link to="/dashboard">Dashboard</Link>}{loggedIn&&<Link to="/water-tests">Water Tests</Link>}{loggedIn&&<Link to="/finance">Finance</Link>}{loggedIn&&<Link to="/invoices">Invoices</Link>}{loggedIn&&<Link to="/maintenance">Maintenance</Link>}{!loggedIn?<Link to="/login">Staff Login</Link>:<button onClick={logout}>Logout</button>}</div></nav>}
  export default function Home(){return <main><section className="hero"><img src="/vivapure-logo.jpeg" alt="VivaPure logo" className="logo"/><h1>VivaPure Water</h1><p className="tagline">Bottled at the source. Purified with care.</p><p>VivaPure Water is sourced from a 50 metre aquifer near the famous Cullinan Diamond Mine and prepared through a Reverse Osmosis filtration system for clean, refreshing drinking water.</p><a className="cta" href="/contact">Contact Sales</a></section><section className="grid"><div className="card"><h2>Source Water</h2><p>Drawn from a deep aquifer in the Cullinan area.</p></div><div className="card"><h2>RO Filtration</h2><p>Prepared using reverse osmosis filtration for consistent quality.</p></div><div className="card"><h2>Local Supply</h2><p>Supplying homes, schools, events, offices and community projects.</p></div></section></main>}
  export default function Contact(){return <main className="page"><h1>Contact VivaPure</h1><div className="card"><p><strong>Address:</strong> Viva Connect, Portion 8 of the farm Louwsbaken, Cullinan 1000</p><p><strong>Telephone:</strong> 082 228 6187</p><p><strong>Email:</strong> info@vivafoundation.life</p><p><strong>Sales:</strong> Leon Kriel - 079 733 1415</p></div></main>}
  import {useState} from 'react';import {useNavigate} from 'react-router-dom';export default function Login(){const[password,setPassword]=useState('');const navigate=useNavigate();function login(e){e.preventDefault();if(password==='ChangeMe123'){localStorage.setItem('vivapure_staff','true');navigate('/dashboard')}else alert('Incorrect password')}return <main className="page narrow"><h1>Staff Login</h1><form className="card" onSubmit={login}><label>Password</label><input type="password" value={password} onChange={e=>setPassword(e.target.value)}/><button type="submit">Login</button><small>Temporary demo password: ChangeMe123. Replace with Supabase Auth before live use.</small></form></main>}
  export default function Dashboard(){const waterTests=JSON.parse(localStorage.getItem('water_tests')||'[]');const finance=JSON.parse(localStorage.getItem('finance_records')||'[]');const maintenance=JSON.parse(localStorage.getItem('maintenance_logs')||'[]');const income=finance.filter(x=>x.type==='Income').reduce((s,x)=>s+Number(x.amount||0),0);const expenses=finance.filter(x=>x.type==='Expense').reduce((s,x)=>s+Number(x.amount||0),0);return <main className="page"><h1>Business Dashboard</h1><section className="grid"><div className="card"><h2>Water Tests</h2><p className="big">{waterTests.length}</p></div><div className="card"><h2>Income</h2><p className="big">R {income.toFixed(2)}</p></div><div className="card"><h2>Expenses</h2><p className="big">R {expenses.toFixed(2)}</p></div><div className="card"><h2>Maintenance Logs</h2><p className="big">{maintenance.length}</p></div></section></main>}
  import {useState} from 'react';export default function Finance(){const[items,setItems]=useState(JSON.parse(localStorage.getItem('finance_records')||'[]'));const[form,setForm]=useState({date:'',type:'Income',description:'',amount:''});function save(e){e.preventDefault();const next=[{...form,id:Date.now()},...items];setItems(next);localStorage.setItem('finance_records',JSON.stringify(next));setForm({date:'',type:'Income',description:'',amount:''})}return <main className="page"><h1>Sales, Income & Expenses</h1><form className="card form-grid" onSubmit={save}><input type="date" value={form.date} onChange={e=>setForm({...form,date:e.target.value})} required/><select value={form.type} onChange={e=>setForm({...form,type:e.target.value})}><option>Income</option><option>Expense</option></select><input placeholder="Description" value={form.description} onChange={e=>setForm({...form,description:e.target.value})}/><input type="number" placeholder="Amount" value={form.amount} onChange={e=>setForm({...form,amount:e.target.value})}/><button>Save Record</button></form><div className="card"><h2>Records</h2>{items.map(x=><p key={x.id}>{x.date} | {x.type} | {x.description} | R {x.amount}</p>)}</div></main>}
  import {useState} from 'react';export default function Invoices(){const[items,setItems]=useState(JSON.parse(localStorage.getItem('invoices')||'[]'));const[form,setForm]=useState({customer:'',date:'',description:'',amount:''});function save(e){e.preventDefault();const invoiceNo='VP-'+String(Date.now()).slice(-6);const next=[{...form,invoiceNo,id:Date.now()},...items];setItems(next);localStorage.setItem('invoices',JSON.stringify(next));setForm({customer:'',date:'',description:'',amount:''})}function printInvoice(x){const html=`<h1>VivaPure Invoice ${x.invoiceNo}</h1><p>Customer: ${x.customer}</p><p>Date: ${x.date}</p><p>${x.description}</p><h2>R ${x.amount}</h2>`;const w=window.open('','_blank');w.document.write(html);w.print()}return <main className="page"><h1>Invoices</h1><form className="card form-grid" onSubmit={save}><input placeholder="Customer" value={form.customer} onChange={e=>setForm({...form,customer:e.target.value})} required/><input type="date" value={form.date} onChange={e=>setForm({...form,date:e.target.value})} required/><input placeholder="Description" value={form.description} onChange={e=>setForm({...form,description:e.target.value})}/><input type="number" placeholder="Amount" value={form.amount} onChange={e=>setForm({...form,amount:e.target.value})}/><button>Create Invoice</button></form><div className="card"><h2>Invoice List</h2>{items.map(x=><p key={x.id}>{x.invoiceNo} | {x.customer} | R {x.amount} <button onClick={()=>printInvoice(x)}>Print</button></p>)}</div></main>}
  import {useState} from 'react';export default function Maintenance(){const[items,setItems]=useState(JSON.parse(localStorage.getItem('maintenance_logs')||'[]'));const[form,setForm]=useState({date:'',item:'',technician:'',notes:''});function save(e){e.preventDefault();const next=[{...form,id:Date.now()},...items];setItems(next);localStorage.setItem('maintenance_logs',JSON.stringify(next));setForm({date:'',item:'',technician:'',notes:''})}return <main className="page"><h1>RO Plant Maintenance Log</h1><form className="card form-grid" onSubmit={save}><input type="date" value={form.date} onChange={e=>setForm({...form,date:e.target.value})} required/><input placeholder="Plant item / filter / pump" value={form.item} onChange={e=>setForm({...form,item:e.target.value})}/><input placeholder="Technician" value={form.technician} onChange={e=>setForm({...form,technician:e.target.value})}/><textarea placeholder="Maintenance notes" value={form.notes} onChange={e=>setForm({...form,notes:e.target.value})}/><button>Save Maintenance Log</button></form><div className="card"><h2>Logs</h2>{items.map(x=><p key={x.id}>{x.date} | {x.item} | {x.technician} | {x.notes}</p>)}</div></main>}
  import {useState} from 'react';export default function WaterTests(){const[items,setItems]=useState(JSON.parse(localStorage.getItem('water_tests')||'[]'));const[form,setForm]=useState({date:'',ph:'',tds:'',conductivity:'',notes:''});function save(e){e.preventDefault();const next=[{...form,id:Date.now()},...items];setItems(next);localStorage.setItem('water_tests',JSON.stringify(next));setForm({date:'',ph:'',tds:'',conductivity:'',notes:''})}return <main className="page"><h1>Water Quality Test Log</h1><form className="card form-grid" onSubmit={save}><input type="date" value={form.date} onChange={e=>setForm({...form,date:e.target.value})} required/><input placeholder="pH" value={form.ph} onChange={e=>setForm({...form,ph:e.target.value})}/><input placeholder="TDS ppm" value={form.tds} onChange={e=>setForm({...form,tds:e.target.value})}/><input placeholder="Conductivity" value={form.conductivity} onChange={e=>setForm({...form,conductivity:e.target.value})}/><textarea placeholder="Notes" value={form.notes} onChange={e=>setForm({...form,notes:e.target.value})}/><button>Save Test</button></form><div className="card"><h2>Records</h2>{items.map(x=><p key={x.id}>{x.date} | pH {x.ph} | TDS {x.tds} | {x.notes}</p>)}</div></main>}
  
